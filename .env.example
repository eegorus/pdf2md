# === Ollama (локальный LLM-сервер, замена OpenAI/Claude) ===
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_FALLBACK_MODEL=qwen2.5vl:7b
OLLAMA_FIGURE_MODEL=qwen2.5vl:3b
# Для сложных документов можно переключить на qwen2.5vl:7b

# === Backend ===
BACKEND_URL=http://backend:8000
LOG_LEVEL=INFO

# === Параметры обработки ===
PDF_DPI=300
MAX_UPLOAD_SIZE_MB=100
BLOCK_CONFIDENCE_THRESHOLD=0.3

# === Fine-tuning ===
MIN_PAIRS_FOR_FINETUNE=50
MODELS_DIR=/app/models
DATA_DIR=/app/data

# OCR Pipeline
OLLAMA_TIMEOUT=300
PYTORCH_ALLOC_CONF=expandable_segments:True
DATA_DIR=/app/data
MODELS_DIR=/app/models
